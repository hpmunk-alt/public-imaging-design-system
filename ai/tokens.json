{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$name": "public imaging — Design Tokens",
  "$version": "1.0",
  "$description": "Markenkonforme Design-Tokens. Schrift ausschließlich Urbanist, kein Times New Roman.",
  "color": {
    "core": {
      "elb-gruen":      { "value": "#15231E", "use": "Primär: dunkle Flächen, Headlines, Text auf Hell" },
      "kontor-leinen":  { "value": "#F6F3ED", "use": "Dominante Hintergrundfarbe (warmes Creme)" },
      "honig-gold":     { "value": "#E6A23C", "use": "Akzent — max. 10 % Fläche pro Ansicht" },
      "speicher-grau":  { "value": "#6A6F6B", "use": "Fließtext, sekundäre UI" },
      "kuehler-salbei": { "value": "#858C84", "use": "Dekorative Flächen, Overlays" },
      "nardo-grau":     { "value": "#838484", "use": "Captions, Metadaten" },
      "soft-black":     { "value": "#0D0D0D", "use": "Tiefster Ton — nie reines #000" },
      "pure-white":     { "value": "#FFFFFF", "use": "Content-Karten, sparsam" }
    },
    "state": {
      "elb-gruen-hover":   { "value": "#1D3029" },
      "elb-gruen-active":  { "value": "#0F1A16" },
      "honig-gold-hover":  { "value": "#D9942F" },
      "honig-gold-active": { "value": "#C68526" },
      "leinen-shade":      { "value": "#ECE7DC" },
      "leinen-shade-2":    { "value": "#E2DCCD" }
    },
    "semantic": {
      "positive": { "value": "#4B7A5E", "use": "Erfolg — gedecktes Salbeigrün" },
      "caution":  { "value": "#C68A2E", "use": "Hinweis — tiefes Gold" },
      "critical": { "value": "#A84B3C", "use": "Fehler — gedecktes Backstein" }
    },
    "alias": {
      "bg":            { "value": "#F6F3ED" },
      "bg-dark":       { "value": "#15231E" },
      "surface":       { "value": "#FFFFFF" },
      "text":          { "value": "#15231E" },
      "text-muted":    { "value": "#6A6F6B" },
      "text-faint":    { "value": "#838484" },
      "text-on-dark":  { "value": "#F6F3ED" },
      "accent":        { "value": "#E6A23C" },
      "line":          { "value": "rgba(21,35,30,0.10)" },
      "line-on-dark":  { "value": "rgba(246,243,237,0.14)" },
      "focus-ring":    { "value": "#E6A23C" }
    }
  },
  "ratio": {
    "$description": "Visuelle Gewichtung pro Ansicht (nicht Pixelzahl)",
    "kontor-leinen": "40%",
    "elb-gruen": "25%",
    "white": "15%",
    "greys": "12%",
    "honig-gold": "8%"
  },
  "typography": {
    "fontFamily": "Urbanist, 'Helvetica Neue', 'Segoe UI', system-ui, sans-serif",
    "rule": "Ausschließlich Urbanist. Times New Roman wird NICHT verwendet.",
    "source": "https://fonts.google.com/specimen/Urbanist",
    "weight": { "light": 300, "regular": 400, "medium": 500, "semibold": 600, "bold": 700, "extrabold": 800 },
    "scale": {
      "2xs": "11px", "xs": "12px", "sm": "14px", "base": "16px", "md": "18px",
      "lg": "24px", "xl": "32px", "2xl": "44px", "3xl": "56px", "4xl": "72px"
    },
    "tracking": {
      "tight": "-0.02em", "tighter": "-0.04em", "normal": "0",
      "wide": "0.12em", "label": "0.2em", "wordmark": "-0.075em"
    },
    "leading": { "display": 1.05, "tight": 1.15, "snug": 1.3, "normal": 1.6, "relaxed": 1.75 },
    "measure": "68ch"
  },
  "space": {
    "1": "4px", "2": "8px", "3": "12px", "4": "16px", "5": "24px",
    "6": "32px", "7": "48px", "8": "64px", "9": "96px", "10": "128px"
  },
  "radius": { "none": "0", "hairline": "2px", "pill": "999px" },
  "shadow": {
    "sm": "0 1px 2px rgba(21,35,30,0.05)",
    "md": "0 8px 24px rgba(21,35,30,0.07)",
    "lg": "0 18px 48px rgba(21,35,30,0.10)"
  },
  "motion": {
    "ease-out": "cubic-bezier(0.22, 1, 0.36, 1)",
    "ease-in-out": "cubic-bezier(0.65, 0, 0.35, 1)",
    "duration-fast": "200ms", "duration-base": "350ms", "duration-slow": "600ms"
  },
  "layout": { "content-max": "1200px", "content-narrow": "760px", "divider-width": "48px" },
  "slide": { "width": "1280px", "height": "720px", "padding": "72px", "accent": "6px", "ratio": "16:9" }
}
